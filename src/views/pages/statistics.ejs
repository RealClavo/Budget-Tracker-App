<section class="page-hero" aria-labelledby="statistics-title">
  <div>
    <p class="section-kicker" data-i18n="pages.statistics.kicker">Inzicht in gedrag</p>
    <h2 id="statistics-title" data-i18n="pages.statistics.title">Statistieken</h2>
  </div>
</section>

<section class="summary-grid">
  <article class="metric-card">
    <span data-i18n="metrics.totalIncome">Totale inkomsten</span>
    <strong data-stats-income>EUR 0.00</strong>
  </article>
  <article class="metric-card">
    <span data-i18n="metrics.totalExpenses">Totale uitgaven</span>
    <strong data-stats-expenses>EUR 0.00</strong>
  </article>
  <article class="metric-card">
    <span data-i18n="metrics.averageDaily">Gemiddeld per dag</span>
    <strong data-stats-average>EUR 0.00</strong>
  </article>
  <article class="metric-card">
    <span data-i18n="metrics.highestCategory">Hoogste categorie</span>
    <strong data-stats-highest>-</strong>
  </article>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3 data-i18n="statistics.categorySpend">Uitgaven per categorie</h3>
    </div>
    <div class="bar-chart" data-category-chart></div>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3 data-i18n="statistics.incomeVsExpenses">Inkomsten versus uitgaven</h3>
    </div>
    <div class="comparison-chart" data-income-expense-chart></div>
  </article>
</section>
