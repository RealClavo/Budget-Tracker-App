<section class="page-hero" aria-labelledby="add-title">
  <div>
    <p class="section-kicker" data-i18n="pages.add.kicker">Nieuwe invoer</p>
    <h2 id="add-title" data-i18n="pages.add.title">Transactie toevoegen</h2>
  </div>
</section>

<section class="panel form-panel">
  <form class="stacked-form" data-transaction-form novalidate>
    <div class="form-grid">
      <label>
        <span data-i18n="form.date">Datum</span>
        <input type="date" name="date" required>
      </label>

      <fieldset>
        <legend data-i18n="form.type">Type</legend>
        <div class="segmented-control">
          <label>
            <input type="radio" name="type" value="income" required>
            <span data-i18n="types.income">Inkomst</span>
          </label>
          <label>
            <input type="radio" name="type" value="expense" checked required>
            <span data-i18n="types.expense">Uitgave</span>
          </label>
        </div>
      </fieldset>

      <label>
        <span data-i18n="form.category">Categorie</span>
        <select name="category" required data-category-select></select>
      </label>

      <label>
        <span data-i18n="form.currency">Valuta</span>
        <select name="currency" required data-currency-select></select>
      </label>

      <label class="form-span">
        <span data-i18n="form.description">Omschrijving</span>
        <input type="text" name="description" maxlength="80" autocomplete="off" required>
      </label>

      <label>
        <span data-i18n="form.amount">Bedrag</span>
        <input type="number" name="amount" min="0.01" step="0.01" inputmode="decimal" required>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit" data-i18n="actions.saveTransaction">Transactie opslaan</button>
      <button class="button button-secondary" type="reset" data-i18n="actions.resetForm">Formulier wissen</button>
    </div>
    <p class="form-status" data-form-status aria-live="polite"></p>
  </form>
</section>
