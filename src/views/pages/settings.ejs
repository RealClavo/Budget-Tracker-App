<section class="page-hero" aria-labelledby="settings-title">
  <div>
    <p class="section-kicker" data-i18n="pages.settings.kicker">Voorkeuren</p>
    <h2 id="settings-title" data-i18n="pages.settings.title">Instellingen</h2>
  </div>
</section>

<section class="content-grid">
  <article class="panel form-panel">
    <form class="stacked-form" data-settings-form novalidate>
      <div class="form-grid">
        <label>
          <span data-i18n="settings.language">Taal</span>
          <select name="language" data-language-select>
            <option value="nl">Nederlands</option>
            <option value="en">English</option>
          </select>
        </label>
        <label>
          <span data-i18n="settings.theme">Thema</span>
          <select name="theme" data-theme-select>
            <option value="dark" data-i18n="theme.dark">Donker</option>
            <option value="light" data-i18n="theme.light">Licht</option>
          </select>
        </label>
        <label>
          <span data-i18n="settings.defaultCurrency">Standaard valuta</span>
          <select name="defaultCurrency" data-default-currency></select>
        </label>
        <label>
          <span data-i18n="settings.monthlyBudget">Maandbudget doel</span>
          <input type="number" name="monthlyBudget" min="0" step="0.01" inputmode="decimal">
        </label>
      </div>
      <div class="form-actions">
        <button class="button button-primary" type="submit" data-i18n="actions.saveSettings">Instellingen opslaan</button>
        <button class="button button-danger" type="button" data-clear-app-data data-i18n="actions.clearAppData">Alle appdata wissen</button>
      </div>
      <p class="form-status" data-settings-status aria-live="polite"></p>
    </form>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3 data-i18n="settings.pwaTitle">PWA informatie</h3>
    </div>
    <p data-i18n="settings.pwaInfo">CashControl kan na het eerste bezoek offline openen en als app worden geinstalleerd.</p>
    <p class="muted" data-install-status aria-live="polite">Installatie beschikbaar wanneer je browser dit ondersteunt.</p>
  </article>
</section>
