<section class="page-hero" aria-labelledby="dashboard-title">
  <div>
    <p class="section-kicker" data-i18n="pages.dashboard.kicker">Vandaag in beeld</p>
    <h2 id="dashboard-title" data-i18n="pages.dashboard.title">Dashboard</h2>
  </div>
  <div class="status-pill" data-online-status aria-live="polite">Online</div>
</section>

<section class="summary-grid" aria-label="Budget samenvatting">
  <article class="metric-card">
    <span data-i18n="metrics.totalIncome">Totale inkomsten</span>
    <strong data-total-income>EUR 0.00</strong>
  </article>
  <article class="metric-card">
    <span data-i18n="metrics.totalExpenses">Totale uitgaven</span>
    <strong data-total-expenses>EUR 0.00</strong>
  </article>
  <article class="metric-card metric-card-accent">
    <span data-i18n="metrics.currentBalance">Huidig saldo</span>
    <strong data-current-balance>EUR 0.00</strong>
  </article>
  <article class="metric-card">
    <span data-i18n="metrics.remainingBudget">Resterend maandbudget</span>
    <strong data-remaining-budget>EUR 0.00</strong>
  </article>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3 data-i18n="dashboard.monthlyProgress">Maandbudget voortgang</h3>
      <span data-budget-percent>0%</span>
    </div>
    <div class="progress-track" aria-label="Maandbudget voortgang">
      <span data-budget-progress style="width: 0%"></span>
    </div>
    <p class="muted" data-i18n="dashboard.monthlyProgressHint">Stel je maandbudget in via Instellingen of de calculator.</p>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3 data-i18n="dashboard.quickSummary">Korte samenvatting</h3>
    </div>
    <dl class="definition-grid">
      <div>
        <dt data-i18n="metrics.transactionCount">Transacties</dt>
        <dd data-transaction-count>0</dd>
      </div>
      <div>
        <dt data-i18n="metrics.highestCategory">Hoogste categorie</dt>
        <dd data-dashboard-highest-category>-</dd>
      </div>
      <div>
        <dt data-i18n="metrics.averageDaily">Gemiddeld per dag</dt>
        <dd data-dashboard-average-daily>EUR 0.00</dd>
      </div>
    </dl>
  </article>
</section>

<section class="panel" aria-labelledby="recent-title">
  <div class="panel-heading">
    <h3 id="recent-title" data-i18n="dashboard.recentTransactions">Recente transacties</h3>
    <a href="./overview.html" data-i18n="actions.viewAll">Bekijk alles</a>
  </div>
  <div class="empty-state" data-dashboard-empty>
    <p data-i18n="transactions.empty">Nog geen transacties opgeslagen.</p>
    <a class="button button-primary" href="./add.html" data-i18n="actions.addTransaction">Transactie toevoegen</a>
  </div>
  <ul class="transaction-list" data-recent-transactions></ul>
</section>
